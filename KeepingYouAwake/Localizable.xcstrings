        "da" : { "stringUnit" : { "state" : "translated", "value" : "Aktivér mens CPU-brugen forbliver over den konfigurerede tærskel" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Aktivieren, solange die CPU-Auslastung über dem festgelegten Schwellenwert bleibt" } },
        "el" : { "stringUnit" : { "state" : "translated", "value" : "Ενεργοποίηση όσο η χρήση CPU παραμένει πάνω από το ρυθμισμένο όριο" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Activar mientras el uso de CPU se mantenga por encima del umbral configurado" } },
