    "You can still manually enable sleep mode for your Mac." : {
      "comment" : "You can still manually enable sleep mode for your Mac.",
      "localizations" : {
                "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Macのスリープは手動で有効にできます。"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan stadig manuelt aktivere vågeblus for din Mac."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst deinen Mac weiterhin manuell in den Ruhezustand versetzen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μπορείτε ακόμα να ενεργοποιήσετε χειροκίνητα την αδράνεια στο Mac σας"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún puedes activar manualmente el modo de reposo en tu Mac."
          }
