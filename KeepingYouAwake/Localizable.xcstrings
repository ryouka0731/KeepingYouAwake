    "Afterwards your Mac will automatically go to sleep again when unused." : {
      "comment" : "Afterwards your Mac will automatically go to sleep again when unused.",
      "localizations" : {
                "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "その後、Macは使用されていないときに再び自動でスリープします。"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Efterfølgende går din Mac automatisk på vågeblus igen, når den ikke bruges."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Mac versetzt sich danach bei Nichtbenutzung wieder selbständig in den Ruhezustand."
          }
        },
        "el" : {
          "stringUnit" : {
